# Porta usada pelo servidor. Plataformas como Render/Railway definem PORT automaticamente.
PORT=3000

# Host público. Use 0.0.0.0 em hospedagens.
HOST=0.0.0.0

# Caminho opcional para o banco JSON. Útil com disco persistente em produção.
# DB_PATH=/data/db.json

# Origem permitida para CORS. Use * somente em protótipo.
CORS_ORIGIN=*

# Banco de dados Supabase/PostgreSQL.
# Use true em produção quando as chaves abaixo estiverem configuradas no Render.
USE_SUPABASE=false
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

# Quantidade máxima de partidas retornadas pela API.
HISTORY_LIMIT=100
