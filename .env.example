# Porta usada pelo servidor. Plataformas como Render/Railway definem PORT automaticamente.
PORT=3000

# Host público. Use 0.0.0.0 em hospedagens.
HOST=0.0.0.0

# Caminho opcional para o banco JSON. Útil com disco persistente em produção.
# DB_PATH=/data/db.json

# Origem permitida para CORS. Use * somente em protótipo.
CORS_ORIGIN=*
